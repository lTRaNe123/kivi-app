#:kivy 2.1.0
#:import dp kivy.metrics.dp


<ScreenTitle@Label>:
    color: 0.04, 0.04, 0.04, 1
    bold: True
    font_size: "30sp"
    halign: "left"
    valign: "middle"
    text_size: self.size
    size_hint_y: None
    height: dp(42)


<ScreenSubtitle@Label>:
    color: 0.22, 0.22, 0.22, 1
    font_size: "14sp"
    halign: "left"
    valign: "top"
    text_size: self.size
    size_hint_y: None
    height: dp(26)


<FinePrint@Label>:
    color: 0.25, 0.25, 0.25, 1
    font_size: "12sp"
    halign: "left"
    valign: "middle"
    text_size: self.size


<CardBox@BoxLayout>:
    padding: dp(16)
    spacing: dp(10)
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(8)]
        Color:
            rgba: 0.86, 0.86, 0.86, 1
        Line:
            rounded_rectangle: self.x, self.y, self.width, self.height, dp(8)
            width: 1


<AppTextInput@TextInput>:
    background_normal: ""
    background_active: ""
    background_color: 0, 0, 0, 0
    foreground_color: 0.05, 0.05, 0.05, 1
    hint_text_color: 0.48, 0.48, 0.48, 1
    cursor_color: 0.05, 0.05, 0.05, 1
    font_size: "16sp"
    padding: dp(14), dp(13)
    size_hint_y: None
    height: dp(52)
    canvas.before:
        Color:
            rgba: 0.98, 0.98, 0.98, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(8)]
        Color:
            rgba: 0.82, 0.82, 0.82, 1
        Line:
            rounded_rectangle: self.x, self.y, self.width, self.height, dp(8)
            width: 1


<PrimaryButton@Button>:
    background_normal: ""
    background_down: ""
    background_color: 0, 0, 0, 0
    color: 1, 1, 1, 1
    bold: True
    font_size: "16sp"
    size_hint_y: None
    height: dp(52)
    canvas.before:
        Color:
            rgba: (0.02, 0.02, 0.02, 1) if self.state == "normal" else (0.16, 0.16, 0.16, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(8)]


<SecondaryButton@Button>:
    background_normal: ""
    background_down: ""
    background_color: 0, 0, 0, 0
    color: 0.05, 0.05, 0.05, 1
    bold: True
    font_size: "14sp"
    size_hint_y: None
    height: dp(44)
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(8)]
        Color:
            rgba: 0.82, 0.82, 0.82, 1
        Line:
            rounded_rectangle: self.x, self.y, self.width, self.height, dp(8)
            width: 1


<MenuCard@Button>:
    background_normal: ""
    background_down: ""
    background_color: 0, 0, 0, 0
    color: 0.05, 0.05, 0.05, 1
    bold: True
    font_size: "17sp"
    halign: "left"
    valign: "middle"
    text_size: self.width - dp(32), self.height
    padding: dp(16), 0
    size_hint_y: None
    height: dp(64)
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(7)]
        Color:
            rgba: 0.86, 0.86, 0.86, 1
        Line:
            rounded_rectangle: self.x, self.y, self.width, self.height, dp(7)
            width: 1


<SectionLabel@Label>:
    color: 0.06, 0.06, 0.06, 1
    bold: True
    font_size: "16sp"
    halign: "left"
    valign: "middle"
    text_size: self.size
    size_hint_y: None
    height: dp(28)


<FinanceTableRow>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(6)]
        Color:
            rgba: 0.9, 0.9, 0.9, 1
        Line:
            rounded_rectangle: self.x, self.y, self.width, self.height, dp(6)
            width: 1
    spacing: dp(4)
    padding: dp(2)


<LoginScreen>:
    login_input: login_input
    password_input: password_input

    FloatLayout:
        canvas.before:
            Color:
                rgba: 0.985, 0.985, 0.975, 1
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            orientation: "vertical"
            spacing: dp(16)
            size_hint: None, None
            width: min(root.width - dp(56), dp(280))
            height: dp(266)
            pos_hint: {"center_x": 0.5, "center_y": 0.52}

            Label:
                text: "ВХОД"
                color: 0.02, 0.02, 0.02, 1
                bold: True
                font_size: "42sp"
                halign: "center"
                valign: "middle"
                text_size: self.size
                size_hint_y: None
                height: dp(64)

            AppTextInput:
                id: login_input
                hint_text: "Логин"
                multiline: False

            AppTextInput:
                id: password_input
                hint_text: "Пароль"
                password: True
                multiline: False

            PrimaryButton:
                text: "Войти"
                on_release: root.do_login()

            Label:
                text: root.message
                color: 0.72, 0.08, 0.08, 1
                font_size: "13sp"
                halign: "center"
                valign: "top"
                text_size: self.size
                size_hint_y: None
                height: dp(34)


<UserHomeScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: dp(24), dp(28)
        spacing: dp(10)
        canvas.before:
            Color:
                rgba: 0.965, 0.965, 0.95, 1
            Rectangle:
                pos: self.pos
                size: self.size

        ScreenTitle:
            text: "ПРИХОЖАЯ"

        ScreenSubtitle:
            text: "Главное меню приложения"

        Label:
            id: lbl_user_name
            text: "ФИО"
            color: 0.12, 0.12, 0.12, 1
            bold: True
            font_size: "15sp"
            halign: "left"
            valign: "middle"
            text_size: self.size
            size_hint_y: None
            height: dp(24)

        Label:
            id: lbl_user_info
            text: "Звание / должность / подразделение"
            color: 0.35, 0.35, 0.35, 1
            font_size: "12sp"
            halign: "left"
            valign: "top"
            text_size: self.size
            size_hint_y: None
            height: dp(42)

        MenuCard:
            text: "1.   Личный кабинет"
            on_release: root.goto_finance()

        MenuCard:
            id: btn_voentorg
            text: "2.   Военторг"
            height: 0 if self.disabled else dp(64)
            opacity: 0 if self.disabled else 1
            on_release: root.goto_voentorg()

        MenuCard:
            id: btn_employee
            text: "3.   Панель сотрудника"
            height: 0 if self.disabled else dp(64)
            opacity: 0 if self.disabled else 1
            on_release: root.goto_employee_panel()

        Widget:

        FinePrint:
            text: "ⓘ  Состав разделов зависит от роли, подразделения и уровня доступа пользователя"
            size_hint_y: None
            height: dp(42)

        FinePrint:
            text: root.status_text
            color: 0.72, 0.08, 0.08, 1
            size_hint_y: None
            height: dp(28)

        SecondaryButton:
            text: "Выйти"
            on_release:
                app.current_user = None
                app.root.current = "login"


<FinanceAccountScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: dp(16), dp(20)
        spacing: dp(10)
        canvas.before:
            Color:
                rgba: 0.965, 0.965, 0.95, 1
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            size_hint_y: None
            height: dp(44)
            spacing: dp(8)

            SecondaryButton:
                text: "Назад"
                size_hint_x: None
                width: dp(92)
                on_release: root.goto_home()

            SecondaryButton:
                text: "Обновить"
                size_hint_x: None
                width: dp(112)
                on_release: root.refresh()

        ScreenTitle:
            text: "ЛИЧНЫЙ КАБИНЕТ"

        ScreenSubtitle:
            text: "Баланс, операции, перевод и вывод ST"

        CardBox:
            orientation: "vertical"
            size_hint_y: None
            height: dp(82)

            Label:
                text: "Текущий баланс"
                color: 0.34, 0.34, 0.34, 1
                font_size: "13sp"
                halign: "left"
                valign: "middle"
                text_size: self.size
                size_hint_y: None
                height: dp(20)

            Label:
                text: root.balance_text.replace("Баланс: ", "")
                color: 0.03, 0.03, 0.03, 1
                bold: True
                font_size: "24sp"
                halign: "left"
                valign: "middle"
                text_size: self.size

        AppTextInput:
            id: search_input
            hint_text: "Поиск по операциям"
            multiline: False
            on_text_validate: root.refresh()

        CardBox:
            orientation: "vertical"
            size_hint_y: None
            height: dp(162)

            SectionLabel:
                text: "Перевод средств"

            Spinner:
                id: finance_receiver
                text: "Получатель"
                values: ()
                size_hint_y: None
                height: dp(44)
                background_normal: ""
                background_color: 1, 1, 1, 1
                color: 0.05, 0.05, 0.05, 1
                on_text: root.on_receiver_selected(self.text)

            BoxLayout:
                spacing: dp(8)
                size_hint_y: None
                height: dp(44)

                AppTextInput:
                    id: transfer_amount
                    hint_text: "Сумма ST"
                    input_filter: "float"
                    multiline: False

                PrimaryButton:
                    text: "Перевести"
                    size_hint_x: None
                    width: dp(120)
                    on_release: root.send_transfer()

        AppTextInput:
            id: transfer_comment
            hint_text: "Комментарий к переводу"
            multiline: False

        CardBox:
            orientation: "vertical"
            size_hint_y: None
            height: dp(114)

            SectionLabel:
                text: "Вывод средств"

            BoxLayout:
                spacing: dp(8)
                size_hint_y: None
                height: dp(44)

                AppTextInput:
                    id: withdraw_amount
                    hint_text: "Сумма вывода ST"
                    input_filter: "float"
                    multiline: False

                PrimaryButton:
                    text: "Вывести"
                    size_hint_x: None
                    width: dp(112)
                    on_release: root.send_withdraw()

        AppTextInput:
            id: withdraw_comment
            hint_text: "Куда вывести / реквизиты / комментарий"
            multiline: False

        SectionLabel:
            text: "История операций"

        ScrollView:
            do_scroll_x: True
            do_scroll_y: False
            size_hint_y: None
            height: dp(42)
            bar_width: dp(6)

            BoxLayout:
                id: finance_header
                orientation: "horizontal"
                size_hint_x: None
                height: dp(42)

        RecycleView:
            id: finance_table
            viewclass: "FinanceTableRow"
            do_scroll_x: True
            do_scroll_y: True
            scroll_type: ["bars", "content"]
            bar_width: dp(6)

            RecycleBoxLayout:
                default_size: root.table_width, dp(52)
                default_size_hint: None, None
                size_hint: None, None
                width: root.table_width
                height: self.minimum_height
                orientation: "vertical"

        Label:
            text: root.status_text
            color: 0.28, 0.28, 0.28, 1
            font_size: "12sp"
            halign: "left"
            valign: "middle"
            text_size: self.size
            size_hint_y: None
            height: dp(24)


<VoentorgScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: dp(24), dp(28)
        spacing: dp(12)
        canvas.before:
            Color:
                rgba: 0.965, 0.965, 0.95, 1
            Rectangle:
                pos: self.pos
                size: self.size

        SecondaryButton:
            text: "Назад"
            size_hint_x: None
            width: dp(92)
            on_release: root.goto_home()

        ScreenTitle:
            text: "ВОЕНТОРГ"

        ScreenSubtitle:
            text: "Заказы, статусы и карточки шевронов"

        BoxLayout:
            id: voentorg_cards
            orientation: "vertical"
            spacing: dp(10)
            size_hint_y: None
            height: self.minimum_height

        Widget:

        FinePrint:
            text: "Раздел подготовлен в едином стиле. API заказов подключается отдельным этапом."
            size_hint_y: None
            height: dp(42)


<EmployeePanelScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: dp(24), dp(28)
        spacing: dp(12)
        canvas.before:
            Color:
                rgba: 0.965, 0.965, 0.95, 1
            Rectangle:
                pos: self.pos
                size: self.size

        SecondaryButton:
            text: "Назад"
            size_hint_x: None
            width: dp(92)
            on_release: root.goto_home()

        ScreenTitle:
            text: "ПАНЕЛЬ СОТРУДНИКА"

        ScreenSubtitle:
            text: "Рабочие роли и быстрый доступ"

        BoxLayout:
            id: employee_cards
            orientation: "vertical"
            spacing: dp(10)
            size_hint_y: None
            height: self.minimum_height

        Widget:

        FinePrint:
            text: "Доступ к веткам зависит от должности, роли и уровня прав пользователя."
            size_hint_y: None
            height: dp(42)


<TransferListScreen>:
    incoming_box: box_incoming
    outgoing_box: box_outgoing

    BoxLayout:
        orientation: "vertical"
        padding: dp(16)
        spacing: dp(8)

        BoxLayout:
            size_hint_y: None
            height: dp(40)
            spacing: dp(8)

            Button:
                text: "Обновить"
                on_release: root.refresh()

            Button:
                text: "Создать передачу"
                on_release: root.goto_create()

            Button:
                text: "Назад"
                on_release: root.goto_home()

        Label:
            text: "Входящие (ожидают моего решения):"
            size_hint_y: None
            height: self.texture_size[1] + dp(4)

        ScrollView:
            size_hint_y: 0.4
            BoxLayout:
                id: box_incoming
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height

        Label:
            text: "Исходящие:"
            size_hint_y: None
            height: self.texture_size[1] + dp(4)

        ScrollView:
            size_hint_y: 0.4
            BoxLayout:
                id: box_outgoing
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height

        Label:
            text: root.status_text
            size_hint_y: None
            height: dp(24)


<TransferCreateScreen>:
    receiver_spinner: sp_receiver
    comment_input: inp_comment
    item_name_input: inp_name
    item_qty_input: inp_qty
    item_unit_input: inp_unit

    BoxLayout:
        orientation: "vertical"
        padding: dp(16)
        spacing: dp(8)

        BoxLayout:
            size_hint_y: None
            height: dp(40)
            spacing: dp(8)

            Button:
                text: "Назад"
                on_release: root.goto_list()

            Button:
                text: "Обновить список людей"
                on_release: root.load_users()

        Label:
            text: "Получатель:"
            size_hint_y: None
            height: self.texture_size[1] + dp(4)

        Spinner:
            id: sp_receiver
            text: "выберите получателя"
            size_hint_y: None
            height: dp(40)
            values: ()
            on_text: root.on_receiver_selected(self.text)

        Label:
            text: "Комментарий:"
            size_hint_y: None
            height: self.texture_size[1] + dp(4)

        TextInput:
            id: inp_comment
            multiline: True
            size_hint_y: None
            height: dp(70)

        Label:
            text: "Предмет 1:"
            size_hint_y: None
            height: self.texture_size[1] + dp(4)

        TextInput:
            id: inp_name
            hint_text: "Название (например: Скотч)"
            size_hint_y: None
            height: dp(40)

        BoxLayout:
            size_hint_y: None
            height: dp(40)
            spacing: dp(8)

            TextInput:
                id: inp_qty
                hint_text: "Кол-во"
                input_filter: "float"

            TextInput:
                id: inp_unit
                hint_text: "Ед. изм. (шт, рул...)"

        Button:
            text: "Отправить передачу"
            size_hint_y: None
            height: dp(40)
            on_release: root.send_transfer()

        Label:
            text: root.status_text
            size_hint_y: None
            height: dp(24)


<FormsMenuScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: dp(16)
        spacing: dp(8)

        BoxLayout:
            size_hint_y: None
            height: dp(40)
            spacing: dp(8)

            Button:
                text: "Назад"
                on_release: app.root.current = "user_home"

            Label:
                text: "Книги / формы"
                halign: "center"
                valign: "middle"
                text_size: self.size

        ScrollView:
            BoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(6)

                Button:
                    text: "Книга №10"
                    size_hint_y: None
                    height: dp(40)
                    on_release: root.open_form("f10", "Книга №10")

                Button:
                    text: "Вечерняя поверка"
                    size_hint_y: None
                    height: dp(40)
                    on_release: root.open_form("evening", "Вечерняя поверка")

                Button:
                    text: "Спальное расположение"
                    size_hint_y: None
                    height: dp(40)
                    on_release: root.open_form("sleep", "Спальное расположение")

                Button:
                    text: "Штатка"
                    size_hint_y: None
                    height: dp(40)
                    on_release: root.open_form("shtatka", "Штатка")

        Label:
            text: ""
            size_hint_y: None
            height: dp(10)


<FormViewScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: dp(10)
        spacing: dp(8)

        BoxLayout:
            size_hint_y: None
            height: dp(40)
            spacing: dp(8)

            Button:
                text: "Назад"
                on_release: app.root.current = "forms_menu"

            Button:
                text: "Обновить"
                on_release: root.load_form()

        Label:
            text: root.title_text
            font_size: "18sp"
            size_hint_y: None
            height: self.texture_size[1] + dp(6)
            halign: "center"
            valign: "middle"
            text_size: self.size

        Label:
            text: root.header_text
            font_size: "16sp"
            size_hint_y: None
            height: self.texture_size[1] + dp(6)
            halign: "center"
            valign: "middle"
            text_size: self.size

        ScrollView:
            do_scroll_x: False
            bar_width: dp(6)

            GridLayout:
                id: lines_grid
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                padding: dp(2), dp(4)
                row_default_height: dp(32)
                row_force_default: False
                spacing: dp(6)

        Label:
            text: root.error_text
            color: 1, 0, 0, 1
            size_hint_y: None
            height: dp(24)
