#:kivy 2.1.0
#:import dp kivy.metrics.dp


<ScreenTitle@Label>:
    color: 0.04, 0.04, 0.04, 1
    bold: True
    font_size: "30sp"
    halign: "left"
    valign: "middle"
    text_size: self.size
    size_hint_y: None
    height: dp(42)


<ScreenSubtitle@Label>:
    color: 0.22, 0.22, 0.22, 1
    font_size: "14sp"
    halign: "left"
    valign: "top"
    text_size: self.size
    size_hint_y: None
    height: dp(26)


<FinePrint@Label>:
    color: 0.25, 0.25, 0.25, 1
    font_size: "12sp"
    halign: "left"
    valign: "middle"
    text_size: self.size


<CardBox@BoxLayout>:
    padding: dp(16)
    spacing: dp(10)
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(8)]
        Color:
            rgba: 0.86, 0.86, 0.86, 1
        Line:
            rounded_rectangle: self.x, self.y, self.width, self.height, dp(8)
            width: 1


<AppTextInput@TextInput>:
    background_normal: ""
    background_active: ""
    background_color: 0, 0, 0, 0
    foreground_color: 0.05, 0.05, 0.05, 1
    hint_text_color: 0.48, 0.48, 0.48, 1
    cursor_color: 0.05, 0.05, 0.05, 1
    font_size: "16sp"
    padding: dp(14), dp(13)
    size_hint_y: None
    height: dp(52)
    canvas.before:
        Color:
            rgba: 0.98, 0.98, 0.98, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(8)]
        Color:
            rgba: 0.82, 0.82, 0.82, 1
        Line:
            rounded_rectangle: self.x, self.y, self.width, self.height, dp(8)
            width: 1


<PrimaryButton@Button>:
    background_normal: ""
    background_down: ""
    background_color: 0, 0, 0, 0
    color: 1, 1, 1, 1
    bold: True
    font_size: "16sp"
    size_hint_y: None
    height: dp(52)
    canvas.before:
        Color:
            rgba: (0.02, 0.02, 0.02, 1) if self.state == "normal" else (0.16, 0.16, 0.16, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(8)]


<SecondaryButton@Button>:
    background_normal: ""
    background_down: ""
    background_color: 0, 0, 0, 0
    color: 0.05, 0.05, 0.05, 1
    bold: True
    font_size: "14sp"
    size_hint_y: None
    height: dp(44)
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(8)]
        Color:
            rgba: 0.82, 0.82, 0.82, 1
        Line:
            rounded_rectangle: self.x, self.y, self.width, self.height, dp(8)
            width: 1


<MenuCard@Button>:
    background_normal: ""
    background_down: ""
    background_color: 0, 0, 0, 0
    color: 0.05, 0.05, 0.05, 1
    bold: True
    font_size: "17sp"
    halign: "left"
    valign: "middle"
    text_size: self.width - dp(32), self.height
    padding: dp(16), 0
    size_hint_y: None
    height: dp(64)
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(7)]
        Color:
            rgba: 0.86, 0.86, 0.86, 1
        Line:
            rounded_rectangle: self.x, self.y, self.width, self.height, dp(7)
            width: 1


<SectionLabel@Label>:
    color: 0.06, 0.06, 0.06, 1
    bold: True
    font_size: "16sp"
    halign: "left"
    valign: "middle"
    text_size: self.size
    size_hint_y: None
    height: dp(28)


<FinanceTableRow>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(6)]
        Color:
            rgba: 0.9, 0.9, 0.9, 1
        Line:
            rounded_rectangle: self.x, self.y, self.width, self.height, dp(6)
            width: 1
    spacing: dp(4)
    padding: dp(2)


<NavListRow>:
    orientation: "horizontal"
    spacing: dp(12)
    padding: dp(12), dp(9)
    size_hint_y: None
    height: dp(68)
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(8)]
        Color:
            rgba: 0.88, 0.88, 0.88, 1
        Line:
            rounded_rectangle: self.x, self.y, self.width, self.height, dp(8)
            width: 1

    Label:
        text: root.icon_text
        color: 0.14, 0.16, 0.12, 1
        bold: True
        font_size: "13sp"
        size_hint_x: None
        width: dp(38)
        halign: "center"
        valign: "middle"
        text_size: self.size
        canvas.before:
            Color:
                rgba: 0.92, 0.94, 0.88, 1
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(19)]

    BoxLayout:
        orientation: "vertical"
        spacing: dp(2)

        Label:
            text: root.title
            color: 0.04, 0.04, 0.04, 1
            bold: True
            font_size: "16sp"
            halign: "left"
            valign: "bottom"
            text_size: self.size

        Label:
            text: root.subtitle
            color: 0.36, 0.36, 0.36, 1
            font_size: "12sp"
            halign: "left"
            valign: "top"
            text_size: self.size

    Label:
        text: ">"
        color: 0.28, 0.28, 0.28, 1
        bold: True
        font_size: "20sp"
        size_hint_x: None
        width: dp(18)
        halign: "center"
        valign: "middle"
        text_size: self.size


<ChevronKitItemRow>:
    orientation: "horizontal"
    spacing: dp(12)
    padding: dp(10)
    size_hint_y: None
    height: dp(106)
    canvas.before:
        Color:
            rgba: 0.08, 0.15, 0.27, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(8)]
        Color:
            rgba: 0.42, 0.55, 0.72, 0.45
        Line:
            rounded_rectangle: self.x, self.y, self.width, self.height, dp(8)
            width: 1

    FloatLayout:
        size_hint_x: None
        width: dp(78)

        Label:
            text: root.placeholder
            color: 0.72, 0.80, 0.90, 1
            bold: True
            font_size: "10sp"
            halign: "center"
            valign: "middle"
            text_size: self.size
            pos_hint: {"center_x": 0.5, "center_y": 0.5}
            size_hint: None, None
            size: dp(72), dp(72)
            canvas.before:
                Color:
                    rgba: 0.10, 0.20, 0.34, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(8)]
                Color:
                    rgba: 0.50, 0.62, 0.78, 0.45
                Line:
                    rounded_rectangle: self.x, self.y, self.width, self.height, dp(8)
                    width: 1

        AsyncImage:
            source: root.image_url
            opacity: 1 if root.image_url else 0
            allow_stretch: True
            keep_ratio: True
            pos_hint: {"center_x": 0.5, "center_y": 0.5}
            size_hint: None, None
            size: dp(72), dp(72)

    BoxLayout:
        orientation: "vertical"
        spacing: dp(6)

        Label:
            text: root.title
            color: 1, 1, 1, 1
            bold: True
            font_size: "13sp"
            halign: "left"
            valign: "bottom"
            text_size: self.size

        Label:
            text: root.meta
            color: 0.70, 0.78, 0.88, 1
            font_size: "12sp"
            halign: "left"
            valign: "top"
            text_size: self.size


<ChevronOptionRow>:
    orientation: "horizontal"
    spacing: dp(10)
    padding: dp(10), dp(7)
    size_hint_y: None
    height: dp(58)
    opacity: 0.48 if root.option_disabled and root.selection_type != "header" else 1
    canvas.before:
        Color:
            rgba: (0.18, 0.37, 0.68, 1) if root.selected else ((0.04, 0.10, 0.20, 1) if root.selection_type == "header" else (0.07, 0.14, 0.25, 1))
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(8)]
        Color:
            rgba: (0.50, 0.58, 0.32, 1) if root.selected else (0.42, 0.55, 0.72, 0.35)
        Line:
            rounded_rectangle: self.x, self.y, self.width, self.height, dp(8)
            width: 1

    Label:
        text: root.mark
        color: 1, 1, 1, 1
        bold: True
        font_size: "17sp"
        size_hint_x: None
        width: dp(26)
        halign: "center"
        valign: "middle"
        text_size: self.size

    BoxLayout:
        orientation: "vertical"
        spacing: dp(2)

        Label:
            text: root.title
            color: 1, 1, 1, 1
            bold: True
            font_size: "14sp" if root.selection_type != "header" else "15sp"
            halign: "left"
            valign: "middle"
            text_size: self.size

        Label:
            text: root.price_text
            color: 0.68, 0.78, 0.90, 1
            font_size: "11sp"
            halign: "left"
            valign: "middle"
            text_size: self.size

    Label:
        text: "выбрано" if root.selected else ""
        color: 0.85, 0.89, 0.70, 1
        font_size: "11sp"
        size_hint_x: None
        width: dp(64)
        halign: "right"
        valign: "middle"
        text_size: self.size


<ChevronNameLineRow>:
    orientation: "horizontal"
    spacing: dp(8)
    padding: dp(10), dp(8)
    size_hint_y: None
    height: dp(62)
    canvas.before:
        Color:
            rgba: 0.07, 0.14, 0.25, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(8)]
        Color:
            rgba: 0.42, 0.55, 0.72, 0.35
        Line:
            rounded_rectangle: self.x, self.y, self.width, self.height, dp(8)
            width: 1

    BoxLayout:
        orientation: "vertical"
        spacing: dp(2)

        Label:
            text: root.text_value
            color: 1, 1, 1, 1
            bold: True
            font_size: "15sp"
            halign: "left"
            valign: "middle"
            text_size: self.size

        Label:
            text: "Количество: " + str(root.quantity)
            color: 0.70, 0.78, 0.88, 1
            font_size: "12sp"
            halign: "left"
            valign: "middle"
            text_size: self.size

    Button:
        text: "-"
        background_normal: ""
        background_down: ""
        background_color: 0.08, 0.15, 0.27, 1
        color: 1, 1, 1, 1
        bold: True
        size_hint_x: None
        width: dp(34)
        on_release: root.increment(-1)

    Button:
        text: "+"
        background_normal: ""
        background_down: ""
        background_color: 0.18, 0.37, 0.68, 1
        color: 1, 1, 1, 1
        bold: True
        size_hint_x: None
        width: dp(34)
        on_release: root.increment(1)

    Button:
        text: "Изм."
        background_normal: ""
        background_down: ""
        background_color: 0.08, 0.15, 0.27, 1
        color: 1, 1, 1, 1
        bold: True
        font_size: "11sp"
        size_hint_x: None
        width: dp(48)
        on_release: root.edit_line()

    Button:
        text: "Удал."
        background_normal: ""
        background_down: ""
        background_color: 0.23, 0.10, 0.12, 1
        color: 1, 1, 1, 1
        bold: True
        font_size: "11sp"
        size_hint_x: None
        width: dp(52)
        on_release: root.remove_line()


<ChevronOrderListRow>:
    orientation: "horizontal"
    spacing: dp(10)
    padding: dp(12), dp(10)
    size_hint_y: None
    height: dp(104)
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(8)]
        Color:
            rgba: 0.82, 0.82, 0.80, 1
        Line:
            rounded_rectangle: self.x, self.y, self.width, self.height, dp(8)
            width: 1

    BoxLayout:
        orientation: "vertical"
        spacing: dp(4)

        BoxLayout:
            size_hint_y: None
            height: dp(24)

            Label:
                text: root.order_number
                color: 0.04, 0.04, 0.04, 1
                bold: True
                font_size: "15sp"
                halign: "left"
                valign: "middle"
                text_size: self.size

            Label:
                text: root.status_text
                color: 1, 1, 1, 1
                bold: True
                font_size: "10sp"
                halign: "center"
                valign: "middle"
                text_size: self.size
                size_hint_x: None
                width: dp(92)
                canvas.before:
                    Color:
                        rgba: root.status_color
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(6)]

        Label:
            text: root.kit_title
            color: 0.08, 0.08, 0.08, 1
            bold: True
            font_size: "14sp"
            halign: "left"
            valign: "middle"
            text_size: self.size

        Label:
            text: root.meta
            color: 0.38, 0.38, 0.38, 1
            font_size: "12sp"
            halign: "left"
            valign: "middle"
            text_size: self.size

        Label:
            text: root.price_text
            color: 0.20, 0.20, 0.20, 1
            font_size: "12sp"
            halign: "left"
            valign: "middle"
            text_size: self.size

    Label:
        text: ">"
        color: 0.20, 0.20, 0.20, 1
        bold: True
        font_size: "20sp"
        size_hint_x: None
        width: dp(18)
        halign: "center"
        valign: "middle"
        text_size: self.size


<EmployeeUserListRow>:
    orientation: "horizontal"
    spacing: dp(10)
    padding: dp(12), dp(10)
    size_hint_y: None
    height: dp(112)
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(8)]
        Color:
            rgba: 0.82, 0.82, 0.80, 1
        Line:
            rounded_rectangle: self.x, self.y, self.width, self.height, dp(8)
            width: 1

    BoxLayout:
        orientation: "vertical"
        spacing: dp(4)

        BoxLayout:
            size_hint_y: None
            height: dp(24)

            Label:
                text: root.title
                color: 0.04, 0.04, 0.04, 1
                bold: True
                font_size: "15sp"
                halign: "left"
                valign: "middle"
                text_size: self.size

            Label:
                text: root.status_text
                color: 1, 1, 1, 1
                bold: True
                font_size: "10sp"
                halign: "center"
                valign: "middle"
                text_size: self.size
                size_hint_x: None
                width: dp(92)
                canvas.before:
                    Color:
                        rgba: root.status_color
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(6)]

        FinePrint:
            text: root.subtitle
            color: 0.30, 0.30, 0.30, 1
            size_hint_y: None
            height: dp(22)

        FinePrint:
            text: root.roles_text
            color: 0.20, 0.20, 0.20, 1
            size_hint_y: None
            height: dp(34)

    Label:
        text: ">"
        color: 0.20, 0.20, 0.20, 1
        bold: True
        font_size: "20sp"
        size_hint_x: None
        width: dp(18)
        halign: "center"
        valign: "middle"
        text_size: self.size


<LoginScreen>:
    login_input: login_input
    password_input: password_input

    FloatLayout:
        canvas.before:
            Color:
                rgba: 0.985, 0.985, 0.975, 1
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            orientation: "vertical"
            spacing: dp(16)
            size_hint: None, None
            width: min(root.width - dp(56), dp(280))
            height: dp(266)
            pos_hint: {"center_x": 0.5, "center_y": 0.52}

            Label:
                text: "ВХОД"
                color: 0.02, 0.02, 0.02, 1
                bold: True
                font_size: "42sp"
                halign: "center"
                valign: "middle"
                text_size: self.size
                size_hint_y: None
                height: dp(64)

            AppTextInput:
                id: login_input
                hint_text: "Логин"
                multiline: False

            AppTextInput:
                id: password_input
                hint_text: "Пароль"
                password: True
                multiline: False

            PrimaryButton:
                text: "Войти"
                on_release: root.do_login()

            Label:
                text: root.message
                color: 0.72, 0.08, 0.08, 1
                font_size: "13sp"
                halign: "center"
                valign: "top"
                text_size: self.size
                size_hint_y: None
                height: dp(34)


<UserHomeScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: dp(24), dp(28)
        spacing: dp(10)
        canvas.before:
            Color:
                rgba: 0.965, 0.965, 0.95, 1
            Rectangle:
                pos: self.pos
                size: self.size

        ScreenTitle:
            text: "ПРИХОЖАЯ"

        ScreenSubtitle:
            text: "Главное меню приложения"

        Label:
            id: lbl_user_name
            text: "ФИО"
            color: 0.12, 0.12, 0.12, 1
            bold: True
            font_size: "15sp"
            halign: "left"
            valign: "middle"
            text_size: self.size
            size_hint_y: None
            height: dp(24)

        Label:
            id: lbl_user_info
            text: "Звание / должность / подразделение"
            color: 0.35, 0.35, 0.35, 1
            font_size: "12sp"
            halign: "left"
            valign: "top"
            text_size: self.size
            size_hint_y: None
            height: dp(42)

        MenuCard:
            text: "1.   Личный кабинет"
            on_release: root.goto_finance()

        MenuCard:
            id: btn_voentorg
            text: "2.   Военторг"
            height: 0 if self.disabled else dp(64)
            opacity: 0 if self.disabled else 1
            on_release: root.goto_voentorg()

        MenuCard:
            id: btn_employee
            text: "3.   Панель сотрудника"
            height: 0 if self.disabled else dp(64)
            opacity: 0 if self.disabled else 1
            on_release: root.goto_employee_panel()

        Widget:

        FinePrint:
            text: "ⓘ  Состав разделов зависит от роли, подразделения и уровня доступа пользователя"
            size_hint_y: None
            height: dp(42)

        FinePrint:
            text: root.status_text
            color: 0.72, 0.08, 0.08, 1
            size_hint_y: None
            height: dp(28)

        SecondaryButton:
            text: "Выйти"
            on_release:
                app.current_user = None
                app.root.current = "login"


<FinanceAccountScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: dp(16), dp(20)
        spacing: dp(10)
        canvas.before:
            Color:
                rgba: 0.965, 0.965, 0.95, 1
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            size_hint_y: None
            height: dp(44)
            spacing: dp(8)

            SecondaryButton:
                text: "Назад"
                size_hint_x: None
                width: dp(92)
                on_release: root.goto_home()

            SecondaryButton:
                text: "Обновить"
                size_hint_x: None
                width: dp(112)
                on_release: root.refresh()

        ScreenTitle:
            text: "ЛИЧНЫЙ КАБИНЕТ"

        ScreenSubtitle:
            text: "Баланс, операции, перевод и вывод ST"

        CardBox:
            orientation: "vertical"
            size_hint_y: None
            height: dp(82)

            Label:
                text: "Текущий баланс"
                color: 0.34, 0.34, 0.34, 1
                font_size: "13sp"
                halign: "left"
                valign: "middle"
                text_size: self.size
                size_hint_y: None
                height: dp(20)

            Label:
                text: root.balance_text.replace("Баланс: ", "")
                color: 0.03, 0.03, 0.03, 1
                bold: True
                font_size: "24sp"
                halign: "left"
                valign: "middle"
                text_size: self.size

        AppTextInput:
            id: search_input
            hint_text: "Поиск по операциям"
            multiline: False
            on_text_validate: root.refresh()

        CardBox:
            orientation: "vertical"
            size_hint_y: None
            height: dp(162)

            SectionLabel:
                text: "Перевод средств"

            Spinner:
                id: finance_receiver
                text: "Получатель"
                values: ()
                size_hint_y: None
                height: dp(44)
                background_normal: ""
                background_color: 1, 1, 1, 1
                color: 0.05, 0.05, 0.05, 1
                on_text: root.on_receiver_selected(self.text)

            BoxLayout:
                spacing: dp(8)
                size_hint_y: None
                height: dp(44)

                AppTextInput:
                    id: transfer_amount
                    hint_text: "Сумма ST"
                    input_filter: "float"
                    multiline: False

                PrimaryButton:
                    text: "Перевести"
                    size_hint_x: None
                    width: dp(120)
                    on_release: root.send_transfer()

        AppTextInput:
            id: transfer_comment
            hint_text: "Комментарий к переводу"
            multiline: False

        CardBox:
            orientation: "vertical"
            size_hint_y: None
            height: dp(114)

            SectionLabel:
                text: "Вывод средств"

            BoxLayout:
                spacing: dp(8)
                size_hint_y: None
                height: dp(44)

                AppTextInput:
                    id: withdraw_amount
                    hint_text: "Сумма вывода ST"
                    input_filter: "float"
                    multiline: False

                PrimaryButton:
                    text: "Вывести"
                    size_hint_x: None
                    width: dp(112)
                    on_release: root.send_withdraw()

        AppTextInput:
            id: withdraw_comment
            hint_text: "Куда вывести / реквизиты / комментарий"
            multiline: False

        SectionLabel:
            text: "История операций"

        ScrollView:
            do_scroll_x: True
            do_scroll_y: False
            size_hint_y: None
            height: dp(42)
            bar_width: dp(6)

            BoxLayout:
                id: finance_header
