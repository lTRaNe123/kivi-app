<ChevronOrdersScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: dp(18), dp(22)
        spacing: dp(10)
        canvas.before:
            Color:
                rgba: 0.965, 0.965, 0.95, 1
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            size_hint_y: None
            height: dp(44)

            SecondaryButton:
                text: "Назад"
                size_hint_x: None
                width: dp(92)
                on_release: root.goto_voentorg()

            Label:
                text: "Мои заказы"
                color: 0.04, 0.04, 0.04, 1
                bold: True
                font_size: "25sp"
                halign: "center"
                valign: "middle"
                text_size: self.size

            SecondaryButton:
                text: "Обновить"
                size_hint_x: None
                width: dp(104)
                on_release: root.load_orders()

        BoxLayout:
            size_hint_y: None
            height: dp(42)
            spacing: dp(6)

            Button:
                text: "Все"
                background_normal: ""
                background_down: ""
                bold: True
                font_size: "12sp"
                background_color: (0.04, 0.04, 0.04, 1) if root.active_status == "" else (0.86, 0.86, 0.84, 1)
                color: (1, 1, 1, 1) if root.active_status == "" else (0.08, 0.08, 0.08, 1)
                on_release: root.select_status("")

            Button:
                text: "Черновики"
                background_normal: ""
                background_down: ""
                bold: True
                font_size: "12sp"
                background_color: (0.04, 0.04, 0.04, 1) if root.active_status == "DRAFT" else (0.86, 0.86, 0.84, 1)
                color: (1, 1, 1, 1) if root.active_status == "DRAFT" else (0.08, 0.08, 0.08, 1)
                on_release: root.select_status("DRAFT")

            Button:
                text: "В работе"
                background_normal: ""
                background_down: ""
                bold: True
                font_size: "12sp"
                background_color: (0.04, 0.04, 0.04, 1) if root.active_status == "IN_WORK" else (0.86, 0.86, 0.84, 1)
                color: (1, 1, 1, 1) if root.active_status == "IN_WORK" else (0.08, 0.08, 0.08, 1)
                on_release: root.select_status("IN_WORK")

        BoxLayout:
            size_hint_y: None
            height: dp(42)
            spacing: dp(6)

            Button:
                text: "Готовые"
                background_normal: ""
                background_down: ""
                bold: True
                font_size: "12sp"
                background_color: (0.04, 0.04, 0.04, 1) if root.active_status == "READY" else (0.86, 0.86, 0.84, 1)
                color: (1, 1, 1, 1) if root.active_status == "READY" else (0.08, 0.08, 0.08, 1)
                on_release: root.select_status("READY")

            Button:
                text: "Завершённые"
                background_normal: ""
                background_down: ""
                bold: True
                font_size: "12sp"
                background_color: (0.04, 0.04, 0.04, 1) if root.active_status == "COMPLETED" else (0.86, 0.86, 0.84, 1)
                color: (1, 1, 1, 1) if root.active_status == "COMPLETED" else (0.08, 0.08, 0.08, 1)
                on_release: root.select_status("COMPLETED")

        RecycleView:
            id: orders_list
            viewclass: "ChevronOrderListRow"
            scroll_type: ["bars", "content"]
            bar_width: dp(4)

            RecycleBoxLayout:
                default_size: None, dp(104)
                default_size_hint: 1, None
                size_hint_y: None
                height: self.minimum_height
                orientation: "vertical"
                spacing: dp(8)

        BoxLayout:
            size_hint_y: None
            height: dp(42)
            spacing: dp(8)

            FinePrint:
                text: "Загрузка..." if root.loading else root.status_text
                color: 0.34, 0.34, 0.34, 1

            SecondaryButton:
                text: "Ещё"
                size_hint_x: None
                width: dp(82)
                disabled: root.loading or not root.has_more
                on_release: root.load_more()


<ChevronOrderDetailScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: dp(18), dp(22)
        spacing: dp(10)
        canvas.before:
            Color:
                rgba: 0.965, 0.965, 0.95, 1
            Rectangle:
                pos: self.pos
                size: self.size

