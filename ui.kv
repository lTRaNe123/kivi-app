                text: root.title_text
                color: 0.04, 0.04, 0.04, 1
                bold: True
                font_size: "21sp"
                halign: "center"
                valign: "middle"
                text_size: self.size

            SecondaryButton:
                text: "Обновить"
                size_hint_x: None
                width: dp(104)
                on_release: root.load_detail()

        ScrollView:
            bar_width: dp(4)

            BoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(10)

                CardBox:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(116)

                    SectionLabel:
                        text: root.status_text

                    FinePrint:
                        text: root.kit_text
                        color: 0.28, 0.28, 0.28, 1

                CardBox:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(148)

                    SectionLabel:
                        text: "Параметры"

                    FinePrint:
                        text: root.config_text
                        color: 0.28, 0.28, 0.28, 1

                CardBox:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(136)

                    SectionLabel:
                        text: "Фамилии / позывные"

                    FinePrint:
                        text: root.lines_text
                        color: 0.28, 0.28, 0.28, 1

                CardBox:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(112)

                    SectionLabel:
                        text: root.price_text

                    FinePrint:
                        text: root.payment_text
                        color: 0.28, 0.28, 0.28, 1

        FinePrint:
            text: "Загрузка..." if root.loading else root.error_text
            color: 0.34, 0.34, 0.34, 1
            size_hint_y: None
            height: dp(28)

        Button:
            text: "Продолжить оформление"
            background_normal: ""
            background_down: ""
            background_color: 0.20, 0.42, 0.78, 1
            color: 1, 1, 1, 1
            bold: True
            font_size: "15sp"
            size_hint_y: None
            height: dp(50)
            opacity: 1 if root.is_draft else 0
            disabled: root.loading or not root.is_draft
            on_release: root.continue_draft()


