                text: "Обновить"
                on_release: root.load_form()

        Label:
            text: root.title_text
            font_size: "18sp"
            size_hint_y: None
            height: self.texture_size[1] + dp(6)
            halign: "center"
            valign: "middle"
            text_size: self.size

        Label:
            text: root.header_text
            font_size: "16sp"
            size_hint_y: None
            height: self.texture_size[1] + dp(6)
            halign: "center"
            valign: "middle"
            text_size: self.size

        ScrollView:
            do_scroll_x: False
            bar_width: dp(6)

