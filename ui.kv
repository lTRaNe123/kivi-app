            Button:
                text: "Обновить"
                on_release: root.refresh()

            Button:
                text: "Создать передачу"
                on_release: root.goto_create()

            Button:
                text: "Назад"
                on_release: root.goto_home()

        Label:
            text: "Входящие (ожидают моего решения):"
            size_hint_y: None
            height: self.texture_size[1] + dp(4)

        ScrollView:
            size_hint_y: 0.4
            BoxLayout:
                id: box_incoming
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height

        Label:
            text: "Исходящие:"
            size_hint_y: None
            height: self.texture_size[1] + dp(4)

        ScrollView:
            size_hint_y: 0.4
            BoxLayout:
                id: box_outgoing
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height

        Label:
            text: root.status_text
            size_hint_y: None
            height: dp(24)


<TransferCreateScreen>:
    receiver_spinner: sp_receiver
    comment_input: inp_comment
    item_name_input: inp_name
    item_qty_input: inp_qty
    item_unit_input: inp_unit

    BoxLayout:
        orientation: "vertical"
        padding: dp(16)
        spacing: dp(8)

        BoxLayout:
            size_hint_y: None
            height: dp(40)
            spacing: dp(8)

            Button:
                text: "Назад"
                on_release: root.goto_list()

            Button:
                text: "Обновить список людей"
                on_release: root.load_users()

        Label:
            text: "Получатель:"
            size_hint_y: None
            height: self.texture_size[1] + dp(4)

        Spinner:
            id: sp_receiver
            text: "выберите получателя"
            size_hint_y: None
            height: dp(40)
            values: ()
            on_text: root.on_receiver_selected(self.text)

        Label:
            text: "Комментарий:"
            size_hint_y: None
            height: self.texture_size[1] + dp(4)

        TextInput:
            id: inp_comment
            multiline: True
            size_hint_y: None
            height: dp(70)

        Label:
            text: "Предмет 1:"
            size_hint_y: None
            height: self.texture_size[1] + dp(4)

        TextInput:
            id: inp_name
            hint_text: "Название (например: Скотч)"
            size_hint_y: None
            height: dp(40)

        BoxLayout:
            size_hint_y: None
            height: dp(40)
            spacing: dp(8)

            TextInput:
                id: inp_qty
                hint_text: "Кол-во"
                input_filter: "float"

            TextInput:
                id: inp_unit
                hint_text: "Ед. изм. (шт, рул...)"

        Button:
            text: "Отправить передачу"
            size_hint_y: None
            height: dp(40)
            on_release: root.send_transfer()

        Label:
            text: root.status_text
            size_hint_y: None
            height: dp(24)


