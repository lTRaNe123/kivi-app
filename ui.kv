<EmployeeOrdersScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: dp(18), dp(22)
        spacing: dp(10)
        canvas.before:
            Color:
                rgba: 0.965, 0.965, 0.95, 1
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            size_hint_y: None
            height: dp(44)

            SecondaryButton:
                text: "Назад"
                size_hint_x: None
                width: dp(92)
                on_release: root.goto_employee()

            Label:
                text: root.role_title
                color: 0.04, 0.04, 0.04, 1
                bold: True
                font_size: "22sp"
                halign: "center"
                valign: "middle"
                text_size: self.size

            SecondaryButton:
                text: "Обновить"
                size_hint_x: None
                width: dp(104)
                on_release: root.load_orders()

        BoxLayout:
            size_hint_y: None
            height: dp(48)
            spacing: dp(8)

            AppTextInput:
                id: employee_search
                hint_text: "Поиск CHV-..."
                multiline: False

            SecondaryButton:
                text: "Найти"
                size_hint_x: None
                width: dp(86)
                on_release: root.load_orders()

        BoxLayout:
            size_hint_y: None
            height: dp(42)
            spacing: dp(6)

            Button:
                text: "Новые"
                background_normal: ""
                background_down: ""
                background_color: (0.45, 0.50, 0.30, 1) if root.queue_mode == "new" else (0.88, 0.88, 0.84, 1)
                color: (1, 1, 1, 1) if root.queue_mode == "new" else (0.06, 0.06, 0.06, 1)
                bold: True
                font_size: "13sp"
                on_release: root.set_queue_mode("new")

            Button:
                text: "Мои"
                background_normal: ""
                background_down: ""
                background_color: (0.45, 0.50, 0.30, 1) if root.queue_mode == "mine" else (0.88, 0.88, 0.84, 1)
                color: (1, 1, 1, 1) if root.queue_mode == "mine" else (0.06, 0.06, 0.06, 1)
                bold: True
                font_size: "13sp"
                on_release: root.set_queue_mode("mine")

            Button:
                text: "Завершил"
                background_normal: ""
                background_down: ""
                background_color: (0.45, 0.50, 0.30, 1) if root.queue_mode == "completed" else (0.88, 0.88, 0.84, 1)
                color: (1, 1, 1, 1) if root.queue_mode == "completed" else (0.06, 0.06, 0.06, 1)
                bold: True
                font_size: "13sp"
                on_release: root.set_queue_mode("completed")

        RecycleView:
            id: employee_orders_list
            viewclass: "ChevronOrderListRow"
            scroll_type: ["bars", "content"]
            bar_width: dp(4)

            RecycleBoxLayout:
                default_size: None, dp(104)
                default_size_hint: 1, None
                size_hint_y: None
                height: self.minimum_height
                orientation: "vertical"
                spacing: dp(8)

        BoxLayout:
            size_hint_y: None
            height: dp(42)
            spacing: dp(8)

            FinePrint:
                text: "Загрузка..." if root.loading else root.status_text
                color: 0.34, 0.34, 0.34, 1

            SecondaryButton:
                text: "Ещё"
                size_hint_x: None
                width: dp(82)
                disabled: root.loading or not root.has_more
                on_release: root.load_more()


<EmployeeOrderDetailScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: dp(18), dp(22)
        spacing: dp(10)
        canvas.before:
            Color:
                rgba: 0.965, 0.965, 0.95, 1
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            size_hint_y: None
            height: dp(44)

            SecondaryButton:
                text: "Назад"
                size_hint_x: None
                width: dp(92)
                on_release: root.goto_queue()

            Label:
                text: root.title_text
                color: 0.04, 0.04, 0.04, 1
                bold: True
                font_size: "21sp"
                halign: "center"
                valign: "middle"
                text_size: self.size

            SecondaryButton:
                text: "Обновить"
                size_hint_x: None
                width: dp(104)
                on_release: root.load_detail()

        ScrollView:
            bar_width: dp(4)

            BoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(10)

                CardBox:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(156)

                    SectionLabel:
                        text: root.status_text

                    FinePrint:
                        text: root.test_text
                        color: 0.45, 0.50, 0.30, 1

                    FinePrint:
                        text: root.kit_text
                        color: 0.28, 0.28, 0.28, 1

                    FinePrint:
                        text: root.action_hint
                        color: 0.70, 0.20, 0.20, 1

                    PrimaryButton:
                        text: root.action_text
                        size_hint_y: None
                        height: dp(42)
                        opacity: 1 if root.action_text else 0
                        disabled: root.loading or root.action_loading or not root.action_enabled
                        on_release: root.run_action()

                CardBox:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(190)

                    SectionLabel:
                        text: "Параметры"

                    FinePrint:
                        text: root.config_text
                        color: 0.28, 0.28, 0.28, 1

                CardBox:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(136)

                    SectionLabel:
                        text: "Фамилии / позывные"

                    FinePrint:
                        text: root.lines_text
                        color: 0.28, 0.28, 0.28, 1

                CardBox:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(90)

                    SectionLabel:
                        text: "Комментарий"

                    FinePrint:
                        text: root.comment_text
                        color: 0.28, 0.28, 0.28, 1

                CardBox:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(150)

                    SectionLabel:
                        text: "История"

                    FinePrint:
                        text: root.history_text
                        color: 0.28, 0.28, 0.28, 1

        FinePrint:
            text: "Загрузка..." if root.loading else root.error_text
            color: 0.34, 0.34, 0.34, 1
            size_hint_y: None
            height: dp(30)


