            color: 0.78, 0.90, 0.82, 1
            font_size: "12sp"
            halign: "center"
            valign: "middle"
            text_size: self.size
            size_hint_y: None
            height: dp(42)

        BoxLayout:
            size_hint_y: None
            height: dp(50)
            spacing: dp(8)

            Button:
                text: root.save_button_text
                background_normal: ""
                background_down: ""
                background_color: (0.11, 0.30, 0.20, 1) if root.saved else (0.08, 0.15, 0.27, 1)
                color: 1, 1, 1, 1
                bold: True
                font_size: "13sp"
                disabled: root.saving or root.saved or root.checking_out
                on_release: root.save_draft()

            Button:
                text: root.checkout_button_text
                background_normal: ""
                background_down: ""
                background_color: 0.20, 0.42, 0.78, 1
                color: 1, 1, 1, 1
                bold: True
                font_size: "13sp"
                disabled: root.saving or root.checking_out
                on_release: root.create_test_order()


