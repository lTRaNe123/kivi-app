#:kivy 2.1.0
#:import dp kivy.metrics.dp


<FinanceTableRow>:
    canvas.before:
        Color:
            rgba: 0.98, 0.98, 0.98, 1
        Rectangle:
            pos: self.pos
            size: self.size
    spacing: dp(1)


<LoginScreen>:
    login_input: login_input
    password_input: password_input

    BoxLayout:
        orientation: "vertical"
        padding: dp(20)
        spacing: dp(10)

        Label:
            text: "Вход в систему"
            font_size: "22sp"
            size_hint_y: None
            height: self.texture_size[1] + dp(10)

        TextInput:
            id: login_input
            hint_text: "Логин"
            multiline: False

        TextInput:
            id: password_input
            hint_text: "Пароль"
            password: True
            multiline: False

        Label:
            text: root.message
            color: 1, 0, 0, 1
            size_hint_y: None
            height: dp(40)

        Button:
            text: "Войти"
            size_hint_y: None
            height: dp(40)
            on_release: root.do_login()


<UserHomeScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: dp(16)
        spacing: dp(12)

        Label:
            id: lbl_user_name
            text: "ФИО"
            font_size: "18sp"
            size_hint_y: None
            height: self.texture_size[1] + dp(6)

        Label:
            id: lbl_user_info
            text: "Звание / должность / подразделение"
            size_hint_y: None
            height: dp(60)

        Button:
            text: "Личный кабинет"
            font_size: "18sp"
            size_hint_y: None
            height: dp(64)
            on_release: root.goto_finance()

        Button:
            id: btn_voentorg
            text: "Военторг"
            font_size: "18sp"
            size_hint_y: None
            height: 0 if self.disabled else dp(64)
            opacity: 0 if self.disabled else 1
            on_release: root.goto_voentorg()

        Button:
            id: btn_employee
            text: "Панель сотрудника"
            font_size: "18sp"
            size_hint_y: None
            height: 0 if self.disabled else dp(64)
            opacity: 0 if self.disabled else 1
            on_release: root.goto_employee_panel()

        Widget:

        Label:
            text: root.status_text
            size_hint_y: None
            height: dp(36)

        BoxLayout:
            size_hint_y: None
            height: dp(40)
            spacing: dp(10)

            Button:
                text: "Выйти"
                on_release:
                    app.current_user = None
                    app.root.current = "login"


<FinanceAccountScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: dp(12)
        spacing: dp(8)

        BoxLayout:
            size_hint_y: None
            height: dp(42)
            spacing: dp(8)

            Button:
                text: "Назад"
                size_hint_x: None
                width: dp(96)
                on_release: root.goto_home()

            Button:
                text: "Обновить"
                size_hint_x: None
                width: dp(116)
                on_release: root.refresh()

            Label:
                text: root.balance_text
                bold: True
                halign: "right"
                valign: "middle"
                text_size: self.size

        TextInput:
            id: search_input
            hint_text: "Поиск по операциям"
            multiline: False
            size_hint_y: None
            height: dp(42)
            on_text_validate: root.refresh()

        BoxLayout:
            size_hint_y: None
            height: dp(42)
            spacing: dp(8)

            Spinner:
                id: finance_receiver
                text: "получатель"
                values: ()
                on_text: root.on_receiver_selected(self.text)

            TextInput:
                id: transfer_amount
                hint_text: "ST"
                input_filter: "float"
                multiline: False
                size_hint_x: None
                width: dp(82)

            Button:
                text: "Перевести"
                size_hint_x: None
                width: dp(112)
                on_release: root.send_transfer()

        TextInput:
            id: transfer_comment
            hint_text: "Комментарий к переводу"
            multiline: False
            size_hint_y: None
            height: dp(38)

        BoxLayout:
            size_hint_y: None
            height: dp(42)
            spacing: dp(8)

            TextInput:
                id: withdraw_amount
                hint_text: "Сумма вывода ST"
                input_filter: "float"
                multiline: False

            Button:
                text: "Вывести"
                size_hint_x: None
                width: dp(112)
                on_release: root.send_withdraw()

        TextInput:
            id: withdraw_comment
            hint_text: "Куда вывести / реквизиты / комментарий"
            multiline: False
            size_hint_y: None
            height: dp(38)

        ScrollView:
            do_scroll_x: True
            do_scroll_y: False
            size_hint_y: None
            height: dp(46)
            bar_width: dp(6)

            BoxLayout:
                id: finance_header
                orientation: "horizontal"
                size_hint_x: None
                height: dp(46)

        RecycleView:
            id: finance_table
            viewclass: "FinanceTableRow"
            do_scroll_x: True
            do_scroll_y: True
            scroll_type: ["bars", "content"]
            bar_width: dp(6)

            RecycleBoxLayout:
                default_size: root.table_width, dp(52)
                default_size_hint: None, None
                size_hint: None, None
                width: root.table_width
                height: self.minimum_height
                orientation: "vertical"

        Label:
            text: root.status_text
            size_hint_y: None
            height: dp(28)


<TransferListScreen>:
    incoming_box: box_incoming
    outgoing_box: box_outgoing

    BoxLayout:
        orientation: "vertical"
        padding: dp(16)
        spacing: dp(8)

        BoxLayout:
            size_hint_y: None
            height: dp(40)
            spacing: dp(8)

            Button:
                text: "Обновить"
                on_release: root.refresh()

            Button:
                text: "Создать передачу"
                on_release: root.goto_create()

            Button:
                text: "Назад"
                on_release: root.goto_home()

        Label:
            text: "Входящие (ожидают моего решения):"
            size_hint_y: None
            height: self.texture_size[1] + dp(4)

        ScrollView:
            size_hint_y: 0.4
            BoxLayout:
                id: box_incoming
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height

        Label:
            text: "Исходящие:"
            size_hint_y: None
            height: self.texture_size[1] + dp(4)

        ScrollView:
            size_hint_y: 0.4
            BoxLayout:
                id: box_outgoing
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height

        Label:
            text: root.status_text
            size_hint_y: None
            height: dp(24)


<TransferCreateScreen>:
    receiver_spinner: sp_receiver
    comment_input: inp_comment
    item_name_input: inp_name
    item_qty_input: inp_qty
    item_unit_input: inp_unit

    BoxLayout:
        orientation: "vertical"
        padding: dp(16)
        spacing: dp(8)

        BoxLayout:
            size_hint_y: None
            height: dp(40)
            spacing: dp(8)

            Button:
                text: "Назад"
                on_release: root.goto_list()

            Button:
                text: "Обновить список людей"
                on_release: root.load_users()

        Label:
            text: "Получатель:"
            size_hint_y: None
            height: self.texture_size[1] + dp(4)

        Spinner:
            id: sp_receiver
            text: "выберите получателя"
            size_hint_y: None
            height: dp(40)
            values: ()
            on_text: root.on_receiver_selected(self.text)

        Label:
            text: "Комментарий:"
            size_hint_y: None
            height: self.texture_size[1] + dp(4)

        TextInput:
            id: inp_comment
            multiline: True
            size_hint_y: None
            height: dp(70)

        Label:
            text: "Предмет 1:"
            size_hint_y: None
            height: self.texture_size[1] + dp(4)

        TextInput:
            id: inp_name
            hint_text: "Название (например: Скотч)"
            size_hint_y: None
            height: dp(40)

        BoxLayout:
            size_hint_y: None
            height: dp(40)
            spacing: dp(8)

            TextInput:
                id: inp_qty
                hint_text: "Кол-во"
                input_filter: "float"

            TextInput:
                id: inp_unit
                hint_text: "Ед. изм. (шт, рул...)"

        Button:
            text: "Отправить передачу"
            size_hint_y: None
            height: dp(40)
            on_release: root.send_transfer()

        Label:
            text: root.status_text
            size_hint_y: None
            height: dp(24)


<FormsMenuScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: dp(16)
        spacing: dp(8)

        BoxLayout:
            size_hint_y: None
            height: dp(40)
            spacing: dp(8)

            Button:
                text: "Назад"
                on_release: app.root.current = "user_home"

            Label:
                text: "Книги / формы"
                halign: "center"
                valign: "middle"
                text_size: self.size

        ScrollView:
            BoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(6)

                Button:
                    text: "Книга №10"
                    size_hint_y: None
                    height: dp(40)
                    on_release: root.open_form("f10", "Книга №10")

                Button:
                    text: "Вечерняя поверка"
                    size_hint_y: None
                    height: dp(40)
                    on_release: root.open_form("evening", "Вечерняя поверка")

                Button:
                    text: "Спальное расположение"
                    size_hint_y: None
                    height: dp(40)
                    on_release: root.open_form("sleep", "Спальное расположение")

                Button:
                    text: "Штатка"
                    size_hint_y: None
                    height: dp(40)
                    on_release: root.open_form("shtatka", "Штатка")

        Label:
            text: ""
            size_hint_y: None
            height: dp(10)


<FormViewScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: dp(10)
        spacing: dp(8)

        BoxLayout:
            size_hint_y: None
            height: dp(40)
            spacing: dp(8)

            Button:
                text: "Назад"
                on_release: app.root.current = "forms_menu"

            Button:
                text: "Обновить"
                on_release: root.load_form()

        Label:
            text: root.title_text
            font_size: "18sp"
            size_hint_y: None
            height: self.texture_size[1] + dp(6)
            halign: "center"
            valign: "middle"
            text_size: self.size

        Label:
            text: root.header_text
            font_size: "16sp"
            size_hint_y: None
            height: self.texture_size[1] + dp(6)
            halign: "center"
            valign: "middle"
            text_size: self.size

        ScrollView:
            do_scroll_x: False
            bar_width: dp(6)

            GridLayout:
                id: lines_grid
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                padding: dp(2), dp(4)
                row_default_height: dp(32)
                row_force_default: False
                spacing: dp(6)

        Label:
            text: root.error_text
            color: 1, 0, 0, 1
            size_hint_y: None
            height: dp(24)
